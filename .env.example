# Port to run the Express server on
PORT=3000

# Google Gemini API Key - Get it from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Twilio Account SID - Found in Twilio Console
TWILIO_ACCOUNT_SID=your_twilio_sid_here

# Twilio Auth Token - Found in Twilio Consolea
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# Twilio WhatsApp/SMS Phone Number
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here
